{
  "name": "cerebral-cortex-monorepo",
  "private": true,
  "engines": {
    "node": "22.x",
    "pnpm": "9.x"
  },
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build:packages": "bash scripts/build.sh packages",
    "build:web": "bash scripts/build.sh web",
    "dev:web": "corepack pnpm --filter web dev",
    "dev:mobile": "corepack pnpm --filter mobile start",
    "build": "bash scripts/build.sh",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint"
  }
}
