project_name = "cerebral-cortex"
region       = "us-east-1"

# Free-tier oriented defaults
instance_type        = "t3.micro"
root_volume_size_gb  = 20
monthly_budget_usd   = 8
emergency_stop_threshold_usd = 10

# Tighten these before production
http_ingress_cidr = "0.0.0.0/0"
enable_ssh        = true
ssh_ingress_cidr  = "0.0.0.0/0"

# Provide either existing_key_name OR ssh_public_key
existing_key_name = ""
ssh_public_key    = "ssh-ed25519 AAAA... your-key"

# Budget alerts
alert_email = "you@example.com"

# UTC schedules (example keeps instance up ~9h/day)
start_schedule_utc = "cron(0 13 * * ? *)"
stop_schedule_utc  = "cron(0 4 * * ? *)"
