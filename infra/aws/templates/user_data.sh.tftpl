#!/bin/bash
set -euxo pipefail

dnf update -y

dnf install -y docker docker-compose-plugin git rsync
systemctl enable --now docker
usermod -aG docker ec2-user

mkdir -p /opt/${project_name}
chown -R ec2-user:ec2-user /opt/${project_name}

cat >/etc/motd <<MOTD
${project_name} host ready.
Sync repository into /opt/${project_name} and start with:
  cd /opt/${project_name}
  docker compose -f infra/docker-compose.aws-lite.yml up -d --build
MOTD
